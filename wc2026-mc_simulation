        "\n",
        "# Distribution des rangs du Sénégal\n",
        "rank_dist = pd.Series(senegal_ranks).value_counts().sort_index()\n",
        "print(f\"Distribution des rangs du Sénégal parmi les 3e:\\n\")\n",
        "for rank, count in rank_dist.items():\n",
        "    pct = (count / n_simulations) * 100\n",
        "    status = \" QUALIFIÉ\" if rank <= 8 else \" ÉLIMINÉ\"\n",
        "    print(f\"   Rang {rank:2d}: {pct:5.1f}% ({count:4d} fois) {status}\")\n",
        "\n",
        "print(f\"\\n   Rang moyen: {pd.Series(senegal_ranks).mean():.1f}\")\n",
        "\n",
        "print(\"\\n\")\n",
        "print(f\"CONCLUSION: {prob_qualification:.2f}% de chance de qualification\")\n"
