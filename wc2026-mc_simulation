        "\n",
        "# 4. WIN PROB with ELO\n",
        "\n",
        "\n",
        "def elo_win_prob(elo_a, elo_b):\n",
        "    \"\"\"P(A gagne) basé sur Elo\"\"\"\n",
        "    return 1 / (1 + 10 ** ((elo_b - elo_a) / 400))\n",
        "\n",
        "\n",
        "# 5. FONCTION: SIMULER UN MATCH\n",
        "\n",
        "\n",
        "def simulate_match(team_a, team_b, elo_a, elo_b, force_win=None):\n",
        "    \"\"\"\n",
        "    Simuler un match\n",
        "    force_win: Si 'A', team_a gagne toujours; si 'B', team_b gagne toujours\n",
        "    Retourne: (goals_a, goals_b)\n",
        "    \"\"\"\n",
        "\n",
        "    p_a_win = elo_win_prob(elo_a, elo_b)\n",
        "\n",
        "    if force_win == 'A':\n",
        "        result = 1\n",
        "    elif force_win == 'B':\n",
        "        result = 0\n",
        "    else:\n",
        "        result = np.random.binomial(1, p_a_win)\n",
        "\n",
        "    # Distribuer les buts réalistement\n",
        "    if result == 1:  # A gagne\n",
        "        goals_a = np.random.choice([1, 2, 3, 4], p=[0.4, 0.35, 0.2, 0.05])\n",
        "        goals_b = np.random.choice([0, 1], p=[0.7, 0.3])\n",
        "    else:  # B gagne\n",
        "        goals_a = np.random.choice([0, 1], p=[0.7, 0.3])\n",
        "        goals_b = np.random.choice([1, 2, 3], p=[0.5, 0.35, 0.15])\n",
        "\n",
        "    return goals_a, goals_b\n",
        "\n",
        "\n",
        "# 6. FONCTION: CALCULER POINTS & CLASSEMENT D'UN GROUPE\n",
        "\n",
        "\n",
        "def calculate_group_standings(group_name, all_match_results):\n",
        "    \"\"\"\n",
        "    Calculer le classement final d'un groupe\n",
        "    all_match_results: dict avec tous les résultats des matchs\n",
        "    \"\"\"\n",
        "    teams = groups[group_name]\n",
        "    standings = {team: {'pts': 0, 'gf': 0, 'ga': 0} for team in teams}\n",
        "\n",
        "    # Ajouter résultats déjà joués\n",
        "    if group_name in played_matches:\n",
        "        for team_a, team_b, ga, gb in played_matches[group_name]:\n",
        "            if ga > gb:\n",
        "                standings[team_a]['pts'] += 3\n",
        "            elif gb > ga:\n",
        "                standings[team_b]['pts'] += 3\n",
        "            else:\n",
        "                standings[team_a]['pts'] += 1\n",
        "                standings[team_b]['pts'] += 1\n",
        "\n",
        "            standings[team_a]['gf'] += ga\n",
        "            standings[team_a]['ga'] += gb\n",
        "            standings[team_b]['gf'] += gb\n",
        "            standings[team_b]['ga'] += ga\n",
        "\n",
        "    # Ajouter résultats du matchday 3 (simulés)\n",
        "    for (grp, team_a, team_b), (goals_a, goals_b) in all_match_results.items():\n",
        "        if grp == group_name:\n",
        "            if goals_a > goals_b:\n",
        "                standings[team_a]['pts'] += 3\n",
        "            elif goals_b > goals_a:\n",
        "                standings[team_b]['pts'] += 3\n",
        "            else:\n",
        "                standings[team_a]['pts'] += 1\n",
        "                standings[team_b]['pts'] += 1\n",
        "\n",
        "            standings[team_a]['gf'] += goals_a\n",
        "            standings[team_a]['ga'] += goals_b\n",
        "            standings[team_b]['gf'] += goals_b\n",
        "            standings[team_b]['ga'] += goals_a\n",
        "\n",
        "    # Trier par points, puis goal diff, puis buts marqués\n",
        "    sorted_teams = sorted(\n",
        "        standings.items(),\n",
        "        key=lambda x: (-x[1]['pts'], -(x[1]['gf'] - x[1]['ga']), -x[1]['gf'])\n",
        "    )\n",
        "\n",
        "    return [(team, data['pts']) for team, data in sorted_teams]\n",
        "\n",
        "\n",
        "# 7. SIMULATION MONTE CARLO\n",
        "\n",
        "\n",
        "n_simulations = 10000\n",
        "senegal_qualified = 0\n",
        "senegal_ranks = []\n",
        "\n",
        "print(f\" Exécution de {n_simulations:,} simulations...\\n\")\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "for sim in range(n_simulations):\n",
        "    # Simuler TOUS les matchs (sauf Sénégal vs Iraq qui GAGNE toujours)\n",
        "    match_results = {}\n",
        "\n",
        "    for group, team_a, team_b in matches_remaining:\n",
        "        elo_a = elo_ratings[team_a]\n",
        "        elo_b = elo_ratings[team_b]\n",
        "\n",
        "        #  FORCER SÉNÉGAL À GAGNER\n",
        "        if team_a == 'Senegal' and team_b == 'Iraq':\n",
        "            goals_a, goals_b = simulate_match(team_a, team_b, elo_a, elo_b, force_win='A')\n",
        "        else:\n",
        "            goals_a, goals_b = simulate_match(team_a, team_b, elo_a, elo_b)\n",
        "\n",
        "        match_results[(group, team_a, team_b)] = (goals_a, goals_b)\n",
        "\n",
        "    # Calculer les classements finaux pour tous les groupes\n",
        "    group_standings = {}\n",
        "    for group_name in groups.keys():\n",
        "        standings = calculate_group_standings(group_name, match_results)\n",
        "        group_standings[group_name] = standings\n",
        "\n",
        "    # Extraire les 3e de chaque groupe\n",
        "    thirds = []\n",
        "    for group_name, standings in group_standings.items():\n",
        "        if len(standings) >= 3:\n",
        "            third_team, third_pts = standings[2]  # 3e position\n",
        "            thirds.append({\n",
        "                'team': third_team,\n",
        "                'points': third_pts,\n",
        "                'group': group_name,\n",
        "                'goal_diff': 0  # Simplifié\n",
        "            })\n",
        "\n",
        "    # Classer les 3e par points (sans tiebreakers)\n",
        "    thirds_sorted = sorted(thirds, key=lambda x: -x['points'])\n",
        "\n",
        "    # Sénégal est dans le top 8?\n",
        "    senegal_rank = 0\n",
        "    for i, third in enumerate(thirds_sorted):\n",
        "        if third['team'] == 'Senegal':\n",
        "            senegal_rank = i + 1\n",
        "            if senegal_rank <= 8:\n",
        "                senegal_qualified += 1\n",
        "            senegal_ranks.append(senegal_rank)\n",
        "            break\n",
        "\n",
        "\n",
        "\n",
        "# 8. RÉSULTATS\n",
        "\n",
        "\n",
        "prob_qualification = (senegal_qualified / n_simulations) * 100\n",
